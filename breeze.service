[Unit]
Description=Breeze Discord Bot Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/cynexbot
ExecStart=/root/cynexbot/venv/bin/python bot.py
Restart=always
RestartSec=5

# Ensure the process restarts if it exits unexpectedly
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
